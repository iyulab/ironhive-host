# IronHive CLI Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Option 1: OpenAI API
# ===========================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Option 2: GpuStack (Self-hosted)
# ===========================================
# GPUSTACK_ENDPOINT=http://localhost:8080
# GPUSTACK_API_KEY=gpustack_xxx
# GPUSTACK_MODEL=gpt-oss-20b
# GPUSTACK_EMBEDDING_MODEL=qwen3-embedding-0.6b
# GPUSTACK_RERANK_MODEL=qwen3-reranker-0.6b

# ===========================================
# LMSupply (Local inference - optional, use /model local)
# ===========================================
# LMSupply is available via '/model local' or '--provider lmsupply'
# It is NOT used as fallback - configure GpuStack/OpenAI for primary use.
# LMSUPPLY_GENERATOR_MODEL=gguf:default

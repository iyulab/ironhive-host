# IronHive CLI Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Option 1: OpenAI API
# ===========================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# Option 2: GpuStack (Self-hosted)
# ===========================================
# GPUSTACK_ENDPOINT=http://localhost:8080
# GPUSTACK_API_KEY=gpustack_xxx
# GPUSTACK_MODEL=gpt-oss-20b
# GPUSTACK_EMBEDDING_MODEL=qwen3-embedding-0.6b
# GPUSTACK_RERANK_MODEL=qwen3-reranker-0.6b

# ===========================================
# Option 3: LMSupply (Local inference - auto fallback)
# ===========================================
# Note: LMSupply is automatically enabled when no remote provider is configured.
# You can explicitly disable it with LMSUPPLY_ENABLED=false
# LMSUPPLY_EMBEDDER_MODEL=auto
# LMSUPPLY_RERANKER_MODEL=auto
# LMSUPPLY_GENERATOR_MODEL=gguf:default
